{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "BANKABLE IQ Brand v1 design tokens. Source: Figma file y3wOnWeFZqJVUH8xi2MoLZ. Exported per Blueprint v1.8.",
  "color": {
    "brand": {
      "indigo":  { "600": { "$value": "#2F2BB8", "$type": "color", "$description": "Brand gradient start (deep)" } },
      "navy":    {
        "700":   { "$value": "#142B66", "$type": "color" },
        "900":   { "$value": "#0A1845", "$type": "color" },
        "950":   { "$value": "#050E2B", "$type": "color", "$description": "Dark mode surface base" }
      },
      "blue":    { "600": { "$value": "#137DC5", "$type": "color", "$description": "Brand gradient mid" } },
      "cyan":    {
        "400":   { "$value": "#7DD3FC", "$type": "color" },
        "500":   { "$value": "#00AEEF", "$type": "color", "$description": "Brand gradient end + primary accent" }
      },
      "violet":  { "400": { "$value": "#B197FC", "$type": "color" } }
    },
    "semantic": {
      "success": { "500": { "$value": "#51CF66", "$type": "color" } },
      "warning": { "500": { "$value": "#FFB347", "$type": "color" } },
      "danger":  { "500": { "$value": "#FF6B6B", "$type": "color" } },
      "info":    { "500": { "$value": "#00AEEF", "$type": "color" } }
    },
    "neutral": {
      "grey":    {
        "400":   { "$value": "#8B9BBF", "$type": "color" },
        "600":   { "$value": "#5A6A8E", "$type": "color" }
      }
    },
    "surface": {
      "bg":       { "$value": "{color.brand.navy.950}", "$type": "color" },
      "elevated": { "$value": "#061128", "$type": "color" },
      "border":   { "$value": "{color.brand.navy.700}", "$type": "color" }
    },
    "text": {
      "primary":   { "$value": "#FFFFFF", "$type": "color" },
      "secondary": { "$value": "{color.neutral.grey.400}", "$type": "color" },
      "accent":    { "$value": "{color.brand.cyan.500}", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "display": { "$value": "Sora, system-ui, -apple-system, sans-serif", "$type": "fontFamily" },
      "body":    { "$value": "Plus Jakarta Sans, system-ui, sans-serif", "$type": "fontFamily" },
      "mono":    { "$value": "JetBrains Mono, ui-monospace, monospace", "$type": "fontFamily" },
      "accent":  { "$value": "Playfair Display, Georgia, serif", "$type": "fontFamily" }
    },
    "weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" },
      "extrabold": { "$value": 800, "$type": "fontWeight" }
    }
  },
  "size": {
    "display": {
      "1": { "$value": "60px", "$type": "dimension" },
      "2": { "$value": "48px", "$type": "dimension" },
      "3": { "$value": "36px", "$type": "dimension" }
    },
    "heading": {
      "1": { "$value": "30px", "$type": "dimension" },
      "2": { "$value": "24px", "$type": "dimension" }
    },
    "body": {
      "lg":      { "$value": "20px", "$type": "dimension" },
      "md":      { "$value": "16px", "$type": "dimension" },
      "sm":      { "$value": "14px", "$type": "dimension" },
      "caption": { "$value": "12px", "$type": "dimension" }
    }
  },
  "space": {
    "1":  { "$value": "4px",  "$type": "dimension" },
    "2":  { "$value": "8px",  "$type": "dimension" },
    "3":  { "$value": "12px", "$type": "dimension" },
    "4":  { "$value": "16px", "$type": "dimension" },
    "5":  { "$value": "20px", "$type": "dimension" },
    "6":  { "$value": "24px", "$type": "dimension" },
    "8":  { "$value": "32px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" }
  },
  "radius": {
    "sm":    { "$value": "4px",  "$type": "dimension" },
    "md":    { "$value": "8px",  "$type": "dimension" },
    "lg":    { "$value": "12px", "$type": "dimension" },
    "xl":    { "$value": "16px", "$type": "dimension" },
    "round": { "$value": "100px", "$type": "dimension" }
  }
}
