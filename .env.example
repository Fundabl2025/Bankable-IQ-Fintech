# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real credentials.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=<YOUR_SUPABASE_PROJECT_URL>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>

# Underwriting partner API — SERVER-SIDE ONLY (no VITE_ prefix)
# Set in Vercel project environment variables, NOT in any .env file.
# Rotate at: Bolt partner dashboard before every deployment if compromised.
BOLT_BROKER_TOKEN=<REDACTED_BOLT_BROKER_TOKEN>

